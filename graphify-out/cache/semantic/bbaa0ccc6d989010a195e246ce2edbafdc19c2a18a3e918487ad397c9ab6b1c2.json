{"nodes": [{"id": "backup_strategy_review_destructive_migration", "label": "Destructive Migration Policy Review", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "fallbackToDestructiveMigration() is dangerous in production because missing migrations will wipe the user database. Explicit migrations must be defined."}, {"id": "backup_strategy_review_ui_driven_backup", "label": "Decouple UI from Backup Trigger", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Backup was triggered directly from LaunchedEffect in UI, leading to concurrency issues. Should be triggered from VM/Repository with debounce."}, {"id": "backup_strategy_review_database_copy_locking", "label": "Atomic Database Copy Locking", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Copying database without write lock causes race conditions. Acquire transaction write lock during checkpoint and copy."}, {"id": "backup_strategy_review_filepath_primary_key", "label": "Stable Primary Key for Uploads", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "File path is unstable PK because paths change. Use stable MediaStore ID and unique fingerprint constraint."}, {"id": "backup_strategy_review_volatile_file_id", "label": "Volatile File ID Refresh", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cached TDLib file IDs are volatile. Treat cached file ID as stale after 30 min and refresh from server if needed."}, {"id": "backup_strategy_review_dedup_fingerprint", "label": "Fingerprint Formula Hardening", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Original fingerprint formula used upload completion time, leading to false negatives. Use MediaStore dateTaken and MD5 of first 64KB."}, {"id": "backup_strategy_review_backup_history", "label": "Rolling Backup History", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deleting old backup immediately leaves user vulnerable to corruption. Keep a rolling window of last 3 backups."}, {"id": "backup_strategy_review_adaptive_throttling", "label": "Adaptive Flood Throttling", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Fixed 5s delay is slow and doesn't handle FLOOD_WAIT. Use adaptive delay responding to Telegram FLOOD_WAIT errors."}, {"id": "backup_strategy_review_album_photo_schema", "label": "Album Photo Schema Refactoring", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sharing a column for local paths and remote IDs is a design smell. Split into two nullable columns."}, {"id": "backup_strategy_review_wakelock_limits", "label": "WakeLock Renewal Strategy", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Static 1-hour WakeLock cut off large uploads. Renew the lock periodically instead."}, {"id": "backup_strategy_review_error_isolation", "label": "Per-Photo Error Isolation", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "One failed photo should not fail the entire sync batch. Wrap individual uploads in try-catch and continue."}, {"id": "backup_strategy_review_checksum_verification", "label": "Post-Upload Checksum Verification", "file_type": "rationale", "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No integrity check after upload. Retrieve document size from Telegram to verify upload completeness."}], "edges": [{"source": "backup_strategy_review_destructive_migration", "target": "storage_uploaddatabase_uploaddatabase", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "weight": 1.0}, {"source": "backup_strategy_review_destructive_migration", "target": "database_and_backup_strategy_migration", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "weight": 1.0}, {"source": "backup_strategy_review_ui_driven_backup", "target": "worker_databasebackupworker_databasebackupworker", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "weight": 1.0}, {"source": "backup_strategy_review_database_copy_locking", "target": "storage_backupmanager_backupdatabase", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.95, "source_file": "BACKUP_STRATEGY_REVIEW.md", "source_location": null, "weight": 1.0}, {"source": "backup_strategy_review_filepath_primary_key", "target": "storage_u